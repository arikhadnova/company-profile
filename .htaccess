# Enable clean URLs for the front controller
# Place this file inside the `public/` folder.

Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /gosirk_website/

    # If the request is for an existing file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Otherwise forward the request to index.php and pass the path as `url`
    RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
</IfModule>
